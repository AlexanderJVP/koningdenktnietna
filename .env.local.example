# Kopieer dit bestand naar .env.local en vul je Stripe sleutels in.
# Je vindt deze op: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# De URL van je website (lokaal of live)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Price IDs — maak producten aan in je Stripe dashboard
# en plak de "Price ID" (begint met price_...) hier.
STRIPE_PRICE_ABRA=price_VERVANG_MIJ
STRIPE_PRICE_HOCUS=price_VERVANG_MIJ

# Formspree ID voor de contactformulieren
# Stap 1: ga naar https://formspree.io en maak een gratis account
# Stap 2: maak een form aan en kopieer de ID (bijv. mijnformulier)
# Stap 3: volg deze links voor BEIDE forms:
#   - Adresformulier (winkel gaat deze gebruiken)
#   - Contactformulier (contact pagina)
NEXT_PUBLIC_FORMSPREE_ID=VERVANG_MIJ
